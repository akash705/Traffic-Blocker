<?xml version="1.0" encoding="utf-8"?>
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">

    <shortcut
        android:shortcutId="start_blocker"
        android:enabled="true"
        android:icon="@drawable/ic_block"
        android:shortcutShortLabel="@string/shortcut_start_label"
        android:shortcutLongLabel="@string/shortcut_start_long_label">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.vedtechnologies.trafficblocker"
            android:targetClass="com.vedtechnologies.trafficblocker.ui.ShortcutActivity">
            <extra
                android:name="action"
                android:value="start" />
        </intent>
    </shortcut>

    <shortcut
        android:shortcutId="stop_blocker"
        android:enabled="true"
        android:icon="@drawable/ic_block"
        android:shortcutShortLabel="@string/shortcut_stop_label"
        android:shortcutLongLabel="@string/shortcut_stop_long_label">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.vedtechnologies.trafficblocker"
            android:targetClass="com.vedtechnologies.trafficblocker.ui.ShortcutActivity">
            <extra
                android:name="action"
                android:value="stop" />
        </intent>
    </shortcut>

</shortcuts>
